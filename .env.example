# CSCD Delegate App — environment template
# Copy to `.env` and fill in the secret values. Never commit `.env`.

# Runtime
NODE_ENV=production
PORT=3000
APP_URL=https://delegateapp.thecscd.org

# Supabase (project: Delegate_app_cscd / govbfxytrdxpmutxbkds)
SUPABASE_URL=https://govbfxytrdxpmutxbkds.supabase.co
# Public, browser-safe key (anon / publishable) — used by the frontend under RLS
SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx
# SECRET — server-only. Never expose to the browser. Used by seed-delegates.js + admin reads.
SUPABASE_SERVICE_ROLE_KEY=

# Email (Resend) — sender domain already verified
RESEND_API_KEY=
FROM_EMAIL=noreply@thecscd.org

# Branding / behaviour
EVENT_NAME=CSCD Delegate App
# Minutes before an item to fire the email reminder (default 60)
REMINDER_LEAD_MINUTES=60

# Interview (AidaForm) — SERVER-ONLY. The base URL is a secret: never expose it
# to the browser. The portal appends the applicant's token as a hidden prefill.
AIDAFORM_BASE_URL=
# The hidden field IDs configured in the AidaForm builder (Set Up > Traits >
# Allow Pre-population). Defaults match the field names below.
AIDAFORM_TOKEN_FIELD=candidate_token
AIDAFORM_APPLICANT_FIELD=applicant_id
# Shared secret for the submission webhook. Give AidaForm this URL:
#   https://<APP_URL>/api/interview/webhook/<AIDAFORM_WEBHOOK_SECRET>
# Generate one with:  node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
AIDAFORM_WEBHOOK_SECRET=
